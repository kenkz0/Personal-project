{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://personal-project-w5dk.onrender.com/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://personal-project-w5dk.onrender.com/health"
    },
    {
      "source": "/((?!api/.*|health).*)",
      "destination": "/index.html"
    }
  ]
}
